PORT=5000
MONGO_URI=mongodb://localhost:27017/employee-management
NODE_ENV=development

# Access token: short-lived, sent in the response body, used as
# "Authorization: Bearer <token>" on every protected request.
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES=15m

# Refresh token: long-lived, sent ONLY as an httpOnly cookie, used to
# silently obtain a new access token when it expires. Use a DIFFERENT
# secret from JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES=7d

CLIENT_URL=http://localhost:5173


SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com